            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"First issue\",\n  \"priority\": \"high\",\n  \"assignedTo\": \"alice\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/issues",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "issues"
          ]
        }
      },
      "response": []
    },
    {
      "name": "List Issues",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/issues",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "issues"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Update Issue",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "name": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"in-progress\",\n  \"assignedTo\": \"bob\"\n}"
